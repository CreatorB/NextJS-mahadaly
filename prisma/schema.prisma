generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Role {
  id       Int    @id @default(autoincrement())
  namaRole String @unique @map("nama_role")
  users    User[]

  @@map("roles")
}

model User {
  id        Int      @id @default(autoincrement())
  nama      String
  email     String   @unique
  password  String
  roleId    Int      @map("role_id")
  role      Role     @relation(fields: [roleId], references: [id])
  isActive  Boolean  @default(true) @map("is_active")
  santriId  Int?     @unique @map("santri_id")
  santri    Santri?  @relation(fields: [santriId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Program {
  id          Int      @id @default(autoincrement())
  namaProgram String   @map("nama_program")
  statusPsb   String   @default("Tutup") @map("status_psb")
  keterangan  String?  @db.Text
  santri      Santri[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("program")
}

model Pekerjaan {
  id        Int      @id @default(autoincrement())
  nama      String
  santri    Santri[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pekerjaan")
}

model InfoPsb {
  id                   Int       @id @default(autoincrement())
  tahunAjaran          String    @unique @map("tahun_ajaran")
  statusPsb            String    @default("Tutup") @map("status_psb")
  datetimeOpen         DateTime? @map("datetime_open")
  datetimeClosed       DateTime? @map("datetime_closed")
  quotaIkhwan          Int?      @map("quota_ikhwan")
  quotaAkhwat          Int?      @map("quota_akhwat")
  biayaPendaftaran     Int       @default(150000) @map("biaya_pendaftaran")
  biayaPangkal         Int       @default(5250000) @map("biaya_pangkal")
  biayaKuliahSemester  Int       @default(3000000) @map("biaya_kuliah_semester")
  biayaCicilanBulanan  Int       @default(500000) @map("biaya_cicilan_bulanan")
  kontenPsb            String?   @db.Text @map("konten_psb")
  posterImages         String?   @db.Text @map("poster_images")
  linkGroup            String?   @map("link_group")
  manualPassword       String?   @map("manual_password")
  santri               Santri[]
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@map("info_psb")
}

model Santri {
  id                  Int       @id @default(autoincrement())
  kodeRegistrasi      String    @unique @map("kode_registrasi")
  noInduk             String?   @map("no_induk")
  nik                 String?
  nisn                String?
  nama                String
  jk                  String
  tmpLahir            String    @map("tmp_lahir")
  tglLahir            DateTime  @map("tgl_lahir")
  alamat              String    @db.Text
  namaAyah            String?   @map("nama_ayah")
  noHpAyah            String?   @map("no_hp_ayah")
  namaIbu             String?   @map("nama_ibu")
  noHpIbu             String?   @map("no_hp_ibu")
  namaWali            String?   @map("nama_wali")
  noHpWali            String?   @map("no_hp_wali")
  pendidikan          String
  pekerjaanId         Int       @map("pekerjaan_id")
  pekerjaan           Pekerjaan @relation(fields: [pekerjaanId], references: [id])
  email               String
  kodeNegara          String    @default("62") @map("kode_negara")
  noHp                String    @map("no_hp")
  hp                  String
  tahunPsb            String    @map("tahun_psb")
  infoPsb             InfoPsb   @relation(fields: [tahunPsb], references: [tahunAjaran])
  programId           Int       @map("program_id")
  program             Program   @relation(fields: [programId], references: [id])
  statusPendaftaran   String    @default("pending") @map("status_pendaftaran")
  alasanPendaftaran   String?   @db.Text @map("alasan_pendaftaran")
  statusTransfer      String    @default("pending") @map("status_transfer")
  alasanTransfer      String?   @db.Text @map("alasan_transfer")
  nominalTransfer     Decimal?  @map("nominal_transfer")
  tglVerifikasi       DateTime? @map("tgl_verifikasi")
  photo               String?
  ktp                 String?
  transfer            String?
  ijazah              String?
  user                User?
  notifications       Notification[]
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("santri")
}

model Notification {
  id        Int      @id @default(autoincrement())
  santriId  Int      @map("santri_id")
  santri    Santri   @relation(fields: [santriId], references: [id])
  type      String
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notifications")
}
